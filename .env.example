# Copy to .env and fill in. Never commit .env.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
# Comma separated. Only needed when DEBUG is false.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Logging verbosity for import runs (DEBUG, INFO, WARNING, ERROR). Logs to
# stdout. DEBUG shows per-page API fetches and per-ride thumbnail renders.
DJANGO_LOG_LEVEL=INFO

# --- Docker: first admin user created on container startup ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com

# --- Database ---
# Leave blank to use a local sqlite file (dev). In production set a Postgres URL:
# DATABASE_URL=postgres://user:password@host:5432/gravelle_estrie
DATABASE_URL=

# --- Static site build ---
# Base path the site will be served from. Leave empty for the custom domain:
# https://www.gravelleestrie.com/
# For project-page hosting, use a leading slash such as /GravelleEstrie.
SITE_BASE_PATH=
SITE_CUSTOM_DOMAIN=www.gravelleestrie.com

# --- RideWithGPS API (https://ridewithgps.com/api) ---
# Primary, bulk import source (see README) — this is what gets you all the
# club's routes with no manual work.
RWGPS_API_KEY=
RWGPS_AUTH_TOKEN=
# User whose routes to import (default: Gravelle Estrie user from SPEC).
RWGPS_USER_ID=4058724
# Additional public/private route ids to import even when they are not owned
# by RWGPS_USER_ID. Comma-separated RideWithGPS route ids.
RWGPS_EXTRA_ROUTE_IDS=
# Known non-bike routes that RideWithGPS currently marks as cycling:gravel.
RWGPS_EXCLUDED_ROUTE_IDS=45012570,45178724

# --- Ravitos ---
# Semicolon-separated list of known convenience stores/grocery stops to show
# on ride detail pages when a route passes nearby.
# Supported entries:
#   https://maps.app.goo.gl/...
#   Name to display|https://www.google.com/maps/place/...
#   Name to display|latitude|longitude
# Short Google Maps links are resolved during build_site, so that command
# needs network access when RAVITO_POINTS contains maps.app.goo.gl URLs.
RAVITO_POINTS=
RAVITO_RADIUS_M=500
# Hide ravitos before riders have covered this route distance from the start.
RAVITO_MIN_ROUTE_DISTANCE_M=30000
# Hide ravitos physically too close to the start or finish point.
RAVITO_ENDPOINT_EXCLUSION_RADIUS_M=3000

# --- Parkings ---
# Same format as RAVITO_POINTS. A parking is shown when it is within
# PARKING_RADIUS_M of the route's first GPS point.
PARKING_POINTS=
PARKING_RADIUS_M=500

# --- Strava API (https://www.strava.com/settings/api) ---
# Secondary/optional. Imports public *routes* (courses), not recorded
# activities. Only needs the basic `read` OAuth scope. Leave STRAVA_ROUTE_IDS
# empty if you don't want any Strava links — RideWithGPS alone is enough.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# A refresh token obtained via the OAuth flow (see README / strava_auth command).
STRAVA_REFRESH_TOKEN=
# Informational only (Strava's API can't list another athlete's routes — see
# README/strava.py). Kept for reference.
STRAVA_ATHLETE_ID=89793076
# Comma-separated numeric route ids to import. Strava has no API to list an
# arbitrary athlete's routes (only your own — see README), so this can only
# ever be a manually curated handful, not the full list: in the Strava app,
# open a route and tap its share icon, and copy the numeric id from the
# resulting strava.com/routes/<id> link.
STRAVA_ROUTE_IDS=
